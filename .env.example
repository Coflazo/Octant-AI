# ──────────────────────────────────────────────────────────────
# Octant AI — Environment Variables Template
# Copy to .env and fill in your values:  cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ── LLM Provider (auto/groq/gemini/ollama/anthropic) ─────────
# "auto" cascades: Groq -> Gemini -> Ollama -> Anthropic
LLM_PROVIDER=auto

# ── LLM API Keys (at least one required) ────────────────────
# Groq: Free tier, 30 req/min — https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# Gemini: Free tier, 15 req/min — https://aistudio.google.com
GEMINI_API_KEY=

# Anthropic: Paid — https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Ollama (local, free) ────────────────────────────────────
# Install: https://ollama.com — then: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Embedding Provider (auto/sentence-transformers/ollama) ──
# "auto" tries sentence-transformers first, then Ollama
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── API Keys (optional) ─────────────────────────────────────
# CORE academic search API — https://core.ac.uk/services/api
CORE_API_KEY=

# ── Report Settings ─────────────────────────────────────────
# Enable AI-pattern detection and rewrite on generated reports
HUMANIZE_REPORTS=true

# ── File Paths ───────────────────────────────────────────────
CHROMA_DB_PATH=./data/chromadb
REPORTS_OUTPUT_PATH=./reports
LATEX_TEMPLATES_PATH=./latex_templates
WSBT_BINARY_PATH=./bin/wsbt

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Server ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
HOST=0.0.0.0
PORT=8000

# ── Optional: Redis (production session store) ──────────────
# REDIS_URL=redis://localhost:6379/0

# ── Pipeline Tuneables ──────────────────────────────────────
MAX_UNIVERSE_SIZE=200
BACKTEST_DEFAULT_PERIOD_YEARS=10
MONTE_CARLO_PATHS=50000
